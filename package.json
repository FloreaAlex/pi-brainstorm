{
	"name": "pi-brainstorm",
	"version": "0.1.0",
	"description": "Multi-agent brainstorming extension for pi coding-agent via ACP",
	"private": true,
	"type": "module",
	"pi": {
		"extensions": ["dist/extension/index.js"]
	},
	"scripts": {
		"wizard": "npm run build && node dist/cli.js wizard",
		"setup": "npm run build && node dist/cli.js setup",
		"doctor": "npm run build && node dist/cli.js doctor",
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest --run",
		"test:e2e": "vitest --run test/e2e-acp.test.ts"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.18.0",
		"chalk": "^5.5.0",
		"strip-ansi": "^7.1.0"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": ">=0.65.0",
		"@mariozechner/pi-tui": ">=0.65.0",
		"@mariozechner/pi-ai": ">=0.65.0",
		"@mariozechner/pi-agent-core": ">=0.65.0"
	},
	"devDependencies": {
		"typescript": "^6.0.0",
		"vitest": "^4.1.0",
		"@mariozechner/pi-coding-agent": "^0.65.0",
		"@mariozechner/pi-tui": "^0.65.0",
		"@mariozechner/pi-ai": "^0.65.0",
		"@mariozechner/pi-agent-core": "^0.65.0"
	}
}
