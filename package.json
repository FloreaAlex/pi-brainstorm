{
	"name": "pi-brainstorm",
	"version": "0.1.0",
	"description": "Multi-agent brainstorming extension for pi coding-agent via ACP",
	"type": "module",
	"pi": {
		"extensions": ["dist/index.js"]
	},
	"scripts": {
		"build": "tsc && cp src/PROMPT.md dist/",
		"dev": "tsc --watch",
		"test": "vitest --run",
		"test:e2e": "vitest --run test/e2e-acp.test.ts"
	},
	"dependencies": {
		"@agentclientprotocol/sdk": "^0.17.0",
		"chalk": "^5.5.0",
		"strip-ansi": "^7.1.0"
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": ">=0.62.0",
		"@mariozechner/pi-tui": ">=0.62.0",
		"@mariozechner/pi-ai": ">=0.62.0",
		"@mariozechner/pi-agent-core": ">=0.62.0"
	},
	"devDependencies": {
		"typescript": "^5.9.2",
		"vitest": "^3.2.0",
		"@mariozechner/pi-coding-agent": "file:../pi-mono/packages/coding-agent",
		"@mariozechner/pi-tui": "file:../pi-mono/packages/tui",
		"@mariozechner/pi-ai": "file:../pi-mono/packages/ai",
		"@mariozechner/pi-agent-core": "file:../pi-mono/packages/agent"
	}
}
